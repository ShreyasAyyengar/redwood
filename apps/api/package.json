{
  "name": "@redwood/api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsgo",
    "typecheck": "tsgo --noEmit",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile api",
    "dev": "bun run --env-file=.env --watch src/index.ts",
    "start": "bun run --env-file=.env src/index.ts",
    "lint": "biome check .",
    "check-types": "tsgo --noEmit"
  },
  "dependencies": {
    "@better-auth/electron": "^1.6.22",
    "@better-auth/expo": "^1.6.22",
    "@elysiajs/cors": "^1.4.2",
    "@orpc/experimental-publisher": "^1.14.6",
    "@orpc/openapi": "^1.14.6",
    "@orpc/server": "^1.14.6",
    "@redwood/contracts": "workspace:*",
    "better-auth": "^1.6.22",
    "csv-parse": "^7.0.0",
    "dotenv": "^17.4.2",
    "elysia": "^1.4.29",
    "mongoose": "^8.24.1",
    "mongoose-zod": "https://github.com/ShreyasAyyengar/mongoose-zod",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^14.0.1"
  },
  "exports": {
    "./auth-server": "./src/libs/auth-server.ts"
  },
  "devDependencies": {
    "@types/node": "^26.0.1"
  }
}
